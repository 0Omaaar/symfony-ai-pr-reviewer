              "value": "={{ $('Webhook').item.json.body.pull_request.number }}",
              "type": "string"
            },
            {
              "id": "field-title",
              "name": "title",
              "value": "={{ $('Webhook').item.json.body.pull_request.title }}",
              "type": "string"
            },
            {
              "id": "field-description",
              "name": "description",
              "value": "={{ $('Webhook').item.json.body.pull_request.body }}",
              "type": "string"
            },
            {
              "id": "field-repo-url",
              "name": "repo_url",
              "value": "={{ $('Webhook').item.json.body.repository.html_url }}",
              "type": "string"
            },
            {
              "id": "field-branch",
              "name": "branch",
              "value": "={{ $('Webhook').item.json.body.pull_request.head.ref }}",
              "type": "string"
            },
            {
              "id": "field-author-token",
              "name": "author_token",
              "value": "",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000003",
      "name": "Extract Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [910, 200]
    },
    {
      "parameters": {
